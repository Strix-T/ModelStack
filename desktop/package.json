{
  "name": "@modelstack/desktop",
  "version": "0.1.3",
  "description": "ModelStack desktop — local AI stack planner",
  "author": "ModelStack contributors",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "pnpm run build && electron-builder --config electron-builder.config.cjs",
    "dist:unsigned": "pnpm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config electron-builder.config.cjs",
    "dist:dir": "pnpm run build && electron-builder --config electron-builder.config.cjs --dir",
    "dist:dir:unsigned": "pnpm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config electron-builder.config.cjs --dir"
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "execa": "^9.6.0",
    "systeminformation": "^5.27.11",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^5.4.14"
  }
}
